# Hypatia Cowork — Environment Configuration
#
# Copy this to .env and fill in your actual keys.
# .env is gitignored — your keys stay local.

# ── Chat model ─────────────────────────────────────────────────────────────────
# Embedded Anthropic API key. There is no user-facing "connect your AI" or
# "paste your API key" UI — the app boots straight into chat, authenticated
# by this key. The server/app boots fine without it; chat requests just fail
# cleanly until it's set.
# - Production builds: baked into the bundle by scripts/prebuild.mjs
# - Dev mode: loaded at sidecar runtime via the repo-root .env (automatic)
ANTHROPIC_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────
# Sidecar log verbosity (error/warn/info/debug/trace). Dev builds default to
# debug (every agent event) unless set here. The Rust app's own log verbosity
# is a separate HYPATIA_LOG_LEVEL — it's read before .env is parsed, so it must
# be exported as a real shell var: `HYPATIA_LOG_LEVEL=info pnpm tauri dev`.
SIDECAR_LOG_LEVEL=info

# ── Analytics & crash reporting ───────────────────────────────────────────────

# Aptabase App Key (for anonymous usage analytics)
# Sign up at https://aptabase.com and create an app.
APTABASE_KEY=

# Sentry DSN (for crash reporting)
# Sign up at https://sentry.io (free tier: 5k events/month).
VITE_SENTRY_DSN=
